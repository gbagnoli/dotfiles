#!/bin/bash

if command -v brew >/dev/null; then
  echo >&2 "* brew update"
  brew update
  echo >&2 "* brew upgrade"
  brew upgrade
  echo >&2 "* brew cleanup"
  brew cleanup --prune=all

  # update also uv tools
  if command -v uv &>/dev/null; then
    echo >&2 "* uv tool upgrade --all"
    uv tool upgrade --all
    echo >&2 "* uv tool clean"
    uv clean
  fi

  if command -v skills &>/dev/null; then
    if ! skills list -g 2>&1 | grep -q "No global skills found"; then
      echo >&2 "* update skills"
      skills update -g
    else
      echo >&2 "* no skills to upgrade"
    fi
  fi

  if [ -L "$0" ] && [ -L "${HOME}/.config/Brewfile" ]; then
    brewfile="$(readlink -f "${HOME}/.config/Brewfile")"
    if [ -f "$brewfile" ]; then
      echo >&2 "* Installing/upgrade brew bundle from $brewfile"
      brew bundle upgrade --file "${brewfile}"
    fi
  fi
fi
